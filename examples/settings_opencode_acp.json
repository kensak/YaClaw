{
    "channel": {
        "discord": {
            "plugin": "channel_discord",
            "channel_id": "${DISCORD_CHANNEL_ID}",
            "bot_token": "${DISCORD_BOT_TOKEN}",
            "agent": "opencode",
            "require_mention": false
        }
    },
    "agent": {
        "opencode": {
            "plugin": "agent_acp",
            "command": "opencode",
            "args": ["acp", "-c"],
            "work_dir": "workspace/opencode",
            "auto_approve": true,
            "output_thought": false
        }
    }
}
