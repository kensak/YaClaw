{
    "channel": {
        "discord": {
            "plugin": "channel_discord",
            "channel_id": "${DISCORD_CHANNEL_ID}",
            "bot_token": "${DISCORD_BOT_TOKEN}",
            "agent": "opencode"
        },
        "schedule": {
            "plugin": "channel_schedule",
            "entry": {
                "morning_routine": {
                    "agent": "opencode",
                    "reply_to": "discord",
                    "everyday_at": "08:00",
                    "message": "What is the weather today?"
                },
                "heartbeat": {
                    "agent": "opencode",
                    "reply_to": "discord",
                    "every_n_minutes": 30,
                    "message": "Is everything okay?"
                }
            }
        }
    },
    "agent": {
        "opencode": {
            "plugin": "agent_acp",
            "command": "opencode",
            "args": ["acp", "-c"],
            "work_dir": "workspace/opencode"
        }
    }
}
