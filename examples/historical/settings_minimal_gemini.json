{
    "channel": {
        "discord": {
            "plugin": "channel_discord",
            "channel_id": "${DISCORD_CHANNEL_ID}",
            "bot_token": "${DISCORD_BOT_TOKEN}",
            "agent": "gemini",
            "require_mention": false
        }
    },
    "agent": {
        "gemini": {
            "plugin": "agent_gemini_cli",
            "work_dir": "workspace/gemini",
            "default_channel": "discord"
        }
    }
}
